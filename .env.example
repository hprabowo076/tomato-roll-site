# Database connection string (runtime — used by the app container)
DATABASE_URL=postgres://postgres:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/tomato-roll

# Database connection string for Docker build time
# Uses host.docker.internal to reach the postgres container from the builder
BUILD_DATABASE_URL=postgres://postgres:REPLACE_WITH_STRONG_PASSWORD@host.docker.internal:5432/tomato-roll

# Used to encrypt JWT tokens — generate with: openssl rand -hex 16
PAYLOAD_SECRET=REPLACE_WITH_RANDOM_SECRET

# Public URL of the app (no trailing slash)
# Set this to your Cloudflare Tunnel domain in production
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs — generate with: openssl rand -hex 16
CRON_SECRET=REPLACE_WITH_RANDOM_SECRET

# Used to validate preview requests — generate with: openssl rand -hex 16
PREVIEW_SECRET=REPLACE_WITH_RANDOM_SECRET

# Cloudflare Tunnel token (from Cloudflare Zero Trust dashboard)
CLOUDFLARED_TOKEN=REPLACE_WITH_YOUR_TUNNEL_TOKEN

# PostgreSQL password (used by docker-compose for the postgres service)
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
